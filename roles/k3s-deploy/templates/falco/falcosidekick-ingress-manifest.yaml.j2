apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: falcosidekick-ingress
  namespace: falco
  annotations:
    traefik.ingress.kubernetes.io/router.tls: "true"
    cert-manager.io/cluster-issuer: "{{ cert_manager_cluster_issuer }}"
spec:
  ingressClassName: traefik
  rules:
  - host: falcosidekick.{{ ingress_hostname }}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: falcosidekick
            port:
              number: 2801
  tls:
  - hosts:
    - falcosidekick.{{ ingress_hostname }}
    secretName: falcosidekick-tls
